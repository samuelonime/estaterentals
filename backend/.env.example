# ============================================
# EstatePro Backend — Environment Variables
# Copy to .env and fill in real values
# ============================================

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/estatepro?schema=public"

# --- JWT ---
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change_this_to_a_random_64_char_hex_string"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change_this_to_another_random_64_char_hex_string"
JWT_REFRESH_EXPIRES_IN="30d"

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=dt3meklxg
CLOUDINARY_API_KEY=886447914375821
CLOUDINARY_API_SECRET=YoRx1D0w6dXoc3hzS-UrlO9IYrc

# --- Server ---
PORT=5000
NODE_ENV="development"

# --- CORS (comma-separated allowed origins) ---
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- Seed Admin Credentials (used only by prisma/seed.ts) ---
# Change these before seeding production!
SEED_ADMIN_EMAIL="admin@estatepro.com"
SEED_ADMIN_PASSWORD="Admin@123456"
SEED_ADMIN_NAME="EstatePro Admin"

# --- Google OAuth ---
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
